{
  "expo": {
    "name": "Align",
    "slug": "align-rn",
    "version": "1.0.0",
    "scheme": "align",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.align.posturecoach"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0E17",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.align.posturecoach"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2F6BFF"
        }
      ],
      "expo-splash-screen",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Align uses your camera so you can take progress photos.",
          "photosPermission": "Align needs access to your photos so you can add progress photos."
        }
      ]
    ]
  }
}
