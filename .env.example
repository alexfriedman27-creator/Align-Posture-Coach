# Copy to .env.local and fill in real values. .env.local is gitignored.
# Only EXPO_PUBLIC_* vars are readable by the app; every value here is a
# PUBLIC/publishable key that is safe to ship in the client bundle.
# Never put a Supabase service_role key or any secret key in this file.

# Supabase (Project Settings -> API). Use the *publishable* anon key (sb_publishable_...).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# RevenueCat public SDK keys (app.revenuecat.com -> API keys).
# Real store keys used in release builds:
EXPO_PUBLIC_RC_IOS_KEY=appl_...
EXPO_PUBLIC_RC_ANDROID_KEY=goog_...
# Test Store key, used automatically in dev builds:
EXPO_PUBLIC_RC_TEST_KEY=test_...
